// This is your entire file – nothing else should remain above
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth core models -----------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String                  @id @default(cuid())
  name                  String?
  email                 String?                 @unique
  emailVerified         DateTime?
  image                 String?
  accounts              Account[]
  sessions              Session[]
  bookings              Booking[]
  volunteerRegistrations VolunteerRegistration[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Accommodation ------------------------------------
model Accommodation {
  id               String   @id @default(cuid())
  name             String
  location         String
  description      String
  energyEfficiency String
  wasteManagement  String
  waterConservation String
  certifications   Json     // e.g. ["LEED Gold", "Green Key"]
  images           Json     // array of URLs
  websiteUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bookings  Booking[]
  ecoRating EcoRating[]
}

// ── Restaurant ---------------------------------------
model Restaurant {
  id               String   @id @default(cuid())
  name             String
  location         String
  description      String
  energyEfficiency String
  wasteManagement  String
  waterConservation String
  certifications   Json
  images           Json
  websiteUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bookings  Booking[]
  ecoRating EcoRating[]
}

// ── ConservationProject ------------------------------
model ConservationProject {
  id               String   @id @default(cuid())
  title            String
  description      String
  location         String
  startDate        DateTime
  endDate          DateTime
  maxVolunteers    Int
  registeredCount  Int      @default(0)
  pointsAwarded    Int
  image            String?
  createdAt        DateTime @default(now())

  registrations VolunteerRegistration[]
}

// ── EcoRating ----------------------------------------
model EcoRating {
  id           String      @id @default(cuid())
  placeId      String
  placeType    PlaceType
  overallScore Int
  factors      Json
  createdAt    DateTime    @default(now())

  accommodation Accommodation? @relation(fields: [placeId], references: [id], onDelete: Cascade, map: "EcoRating_acc_fkey")
  restaurant    Restaurant?    @relation(fields: [placeId], references: [id], onDelete: Cascade, map: "EcoRating_rest_fkey")

  @@unique([placeId, placeType])
}

enum PlaceType {
  ACCOMMODATION
  RESTAURANT
}

// ── Pivot tables -------------------------------------
model Booking {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  placeType PlaceType
  bookedAt  DateTime @default(now())

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accommodation Accommodation?  @relation(fields: [placeId], references: [id], onDelete: Cascade, map: "Booking_acc_fkey")
  restaurant    Restaurant?     @relation(fields: [placeId], references: [id], onDelete: Cascade, map: "Booking_rest_fkey")
}

model VolunteerRegistration {
  id                     String   @id @default(cuid())
  userId                 String
  conservationProjectId  String
  registeredAt           DateTime @default(now())

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  conservationProject ConservationProject @relation(fields: [conservationProjectId], references: [id], onDelete: Cascade)

  @@unique([userId, conservationProjectId])
}